  "description": "Prime-console-aligned operations console with AlphaBitCore brand assets, navy navigation, institutional blue accents, dense tables, and true light/dark surfaces",

  "brand": {
    "productName": "AlphaBitCore",
    "tagline": "Innovate. Invest. Thrive",
    "logoMark": "/brand/prime-console/logo-mark.svg",
