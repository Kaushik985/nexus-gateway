node_modules/
dist/

# nexus-ami staging artifacts populated by nexus-ami/build.sh — the binaries,
# UI dist, and Prisma bundle are derived from the source tree on every build
# and should never be committed. Architecture:
# docs/developers/architecture/cross-cutting/deployment/ami-appliance-architecture.md
nexus-ami/artifacts/bin/
nexus-ami/artifacts/ui-dist/
nexus-ami/artifacts/prisma/
nexus-ami/artifacts/scripts/
nexus-ami/artifacts.tar.gz
# Build-cycle log + tarball rotations created by ./build.sh during iteration.
nexus-ami/artifacts.tar.gz.*
nexus-ami/build.log*
# Packer leaves a manifest + crash log in the working dir.
nexus-ami/packer_cache/
nexus-ami/manifest.json
nexus-ami/crash.log

# Wails dashboard build artefacts (regenerated by `wails build` /
# `wails dev`; bindings are auto-generated from the Go bridge).
# Wails build outputs. Everything is generated EXCEPT:
#   - appicon.png — input brand icon, Wails reads this on every build
#   - darwin/Info.plist — our customised macOS Info.plist template
#     (hardcodes CFBundleIdentifier so the menu-bar Quit handler can
#     find the Dashboard process via NSRunningApplication)
packages/agent/ui/build/*
!packages/agent/ui/build/appicon.png
!packages/agent/ui/build/darwin/
packages/agent/ui/build/darwin/*
!packages/agent/ui/build/darwin/Info.plist
packages/agent/ui/bindings/
packages/agent/ui/frontend/dist/
# Stray binary left by `go build ./packages/agent/ui/` (the package's
# main entry compiles into a `ui` executable next to the source).
# Always a build artefact; never check in. The `/ui` rule below
# also catches a top-level `ui` if `go build` is invoked from repo
# root, but the package-relative path is the common case.
packages/agent/ui/ui
/ui
.env
.claude/settings.local.json
.claude/scheduled_tasks.lock
CLAUDE.local.md
*.tmp
*.log

# Maintainer-local materialized prod configs. The OSS-readiness sweep
# (commit 423c1527b) renamed every *.prod.yaml -> *.prod.yaml.example
# for public-repo hygiene; the unprefixed name is the local copy each
# maintainer fills in with real hostnames + secrets before building or
# deploying. Never check it back in — that's the whole point of the
# rename. Pre-build agent.prod.yaml is the most common case (build-prod.sh
# expects it to exist; build-agent skill creates one on first run).
packages/*/*.prod.yaml
# Dev log directories (log.file paths under packages/*/logs/). Path-anchored
# to avoid catching legitimate source dirs that happen to be named `logs/`
# (e.g. control-plane-ui/.../tabs/logs/ is a UI tab pkg, not a log dir).
/logs/
/packages/*/logs/
.DS_Store
.vite/
coverage/
*.tsbuildinfo

# Stray repo-root binary (e.g. `go build -o compliance-proxy`)
/compliance-proxy
/agent-tray
/agent
/control-plane
/nexus-hub
/ai-gateway

# Generated by rsrc at Windows build time; reproducible from
# packages/agent/platform/windows/NexusAgent/app.manifest.
packages/agent/cmd/agent-tray/*_windows.syso

# Go workspace
go.work.sum

# Go binaries (all packages output to bin/)
packages/ai-gateway/bin/
packages/compliance-proxy/bin/
packages/control-plane/bin/
packages/agent/bin/

# Delve / VSCode Go debug binaries
__debug_bin*

# Legacy binary paths and stale artifacts
packages/agent/agent
packages/agent/agent.exe
packages/agent/nexus-agent
packages/agent/nexus-agent.rollback
packages/ai-gateway/explicit-proxy
packages/compliance-proxy/forward-proxy

# Go service binaries compiled in-tree (go run / go build without -o).
# These match the service name and land next to cmd/<svc>/main.go or at
# package root depending on invocation. Ignore globally so `go build
# ./cmd/<svc>` never pollutes the tree.
packages/ai-gateway/cmd/ai-gateway/ai-gateway
packages/compliance-proxy/cmd/compliance-proxy/compliance-proxy
packages/control-plane/cmd/control-plane/control-plane
packages/control-plane/control-plane
packages/nexus-hub/cmd/nexus-hub/nexus-hub
packages/agent/cmd/agent/agent
packages/explicit-proxy/

# Same binaries but landed at the package ROOT (go build ./cmd/<svc>
# from the package dir, instead of from inside cmd/<svc>/).
packages/ai-gateway/ai-gateway
packages/compliance-proxy/compliance-proxy
packages/nexus-hub/nexus-hub

# Python bytecode caches anywhere (was previously only covered under
# tests/e2e-python/).
**/__pycache__/

# Wails frontend npm-install fingerprint sidecar.
packages/agent/ui/frontend/package.json.md5

# Any native binary or archive at repo root or inside packages/ (catches
# stray Mach-O / ELF / PE artifacts from debug sessions).
*.exe
*.dll
*.dylib
*.so

# Swift Package Manager build cache (NexusAgentUI). Always a local build
# artifact; never source-controlled.
packages/agent/platform/darwin/NexusAgentUI/.build/
packages/agent/platform/darwin/NexusAgentUI/.swiftpm/
# Xcode-driven SwiftPM build dir at the top of platform/darwin (sibling
# to NexusAgentUI/). Holds Intermediates.noindex/, Products/, and the
# DerivedSources tree — hundreds of MB after each build-agent run.
packages/agent/platform/darwin/.build/
# Transient component build dir produced by agent-build-macos before
# the .pkg gets assembled. The .pkg itself stays in dist/macos/.
dist/macos/build/

# Compliance-proxy runtime artifacts
packages/compliance-proxy/dev-certs/
packages/compliance-proxy/audit-spool/

# Control-plane-ui dev TLS certs (per-machine, issued via Let's Encrypt
# DNS-01 against the dev domain; never committed)
packages/control-plane-ui/.certs/

# Agent CA test artifacts
.agent-ca/

# Control-plane dev-only auth keystore (generated on first boot)
packages/control-plane/.nexus/

# Superpowers brainstorming Visual Companion sessions (local-only mockups)
.superpowers/

# Test/skill per-target config (contains VKs / credentials).
# See CLAUDE.md "Test/skill env files live under tests/.env.<target>".
tests/.env.local
tests/.env.dev
tests/.env.prod
/tmp/nexus-test/

# Test program runtime artifacts
tests/e2e-python/.venv/
tests/e2e-python/.pytest_cache/
tests/e2e-python/uv.lock
tests/e2e-python/**/__pycache__/
tests/e2e-ui/node_modules/
tests/e2e-ui/test-results/
tests/e2e-ui/playwright-report/
tests/e2e-ui/.auth/
test-results/
.plans/

# Parallel Claude Code sessions (worktree-per-session convention, 2026-05-20)
worktrees/

# Compiled Go test binaries left behind by `go test -c` (each is the
# size of the package's transitive dependency tree — ~60 MB for the
# wiring sub-pkg; never check in).
*.test


# JetBrains IDE
.idea/
