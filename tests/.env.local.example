# tests/.env.local.example — local-target test/skill env contract.
#
# Copy to tests/.env.local (gitignored) and edit. The bash/Python/Go test
# loaders (tests/lib/loadenv.{sh,py} + tests/integration-go/helpers/env.go)
# pick this file up when NEXUS_TEST_TARGET=local (the default).
#
# Two related contracts:
#   - This file = test/skill runner env (URLs, VKs, admin creds, paths).
#   - repo-root .env = Go service boot env (INTERNAL_SERVICE_TOKEN,
#     ADMIN_KEY_HMAC_SECRET, CREDENTIAL_ENCRYPTION_KEY, …) loaded by
#     packages/shared/bootenv at service startup.
# The two files have overlapping concepts but different consumers — keep
# them in sync where they overlap (e.g. NEXUS_HUB_SERVICE_TOKEN here MUST
# match INTERNAL_SERVICE_TOKEN in repo-root .env).

# --- Service endpoints (localhost only — fail-closed on any other host)----
NEXUS_HUB_URL=http://localhost:3060
NEXUS_CP_URL=http://localhost:3001
NEXUS_AI_GW_URL=http://localhost:3050
NEXUS_PROXY_URL=http://localhost:3040
NEXUS_UI_URL=http://localhost:3000

# --- Postgres (via docker exec) -------------------------------------------
NEXUS_PG_CONTAINER=nexus-postgres
NEXUS_PG_DB=nexus_gateway
NEXUS_PG_USER=postgres

# --- Admin login (real OAuth + PKCE flow) ---------------------------------
NEXUS_ADMIN_EMAIL=admin@nexus.ai
NEXUS_ADMIN_PASSWORD=admin123
NEXUS_OAUTH_CLIENT_ID=cp-ui
NEXUS_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
NEXUS_TOKEN_CACHE=/tmp/nexus_test_token_local

# Hub admin endpoints use the internal service token shared with
# Control Plane / AI Gateway / Compliance Proxy. MUST match
# INTERNAL_SERVICE_TOKEN in repo-root .env (loaded by bootenv into all
# four Go services at boot).
NEXUS_HUB_SERVICE_TOKEN=dev-service-token

# --- AI-judge (Phase 4) ---------------------------------------------------
NEXUS_TEST_VK=nvk_REPLACE_ME
NEXUS_JUDGE_MODEL=moonshot-v1-128k
NEXUS_JUDGE_BASE_URL=http://localhost:3050/v1

# --- Run controls ---------------------------------------------------------
NEXUS_TEST_VERBOSE=0
NEXUS_TEST_LOG_DIR=/tmp/nexus-test

# --- macOS pf gap-closure tests (E74-S7) ----------------------------------
# Set NEXUS_RUN_MACOS_PF_TESTS=true on a macOS dev machine running the
# pf-mode agent daemon to include these tests in tests/run-all.sh.
# Requires: agent with interceptMode=pf, sudo for pfctl, CP on localhost:3128.

# Agent loopback listener address (DEC-005 default: 127.0.0.1:13443).
NEXUS_AGENT_LISTENER_ADDR=127.0.0.1:13443

# Postgres DSN for traffic_event queries. Must be loopback for target=local.
# NEXUS_DB_DSN is already required by other test phases — no duplicate entry.

# Agent Prometheus metrics endpoint.
NEXUS_PROMETHEUS_ADDR=http://localhost:9100

# Gap 2: QUIC-capable target host for the UDP-fallback test.
NEXUS_GAP2_TARGET_HOST=chatgpt.com

# Gap 3: load test parameters.
NEXUS_GAP3_CONCURRENCY=10
NEXUS_GAP3_DURATION_S=60
NEXUS_GAP3_TARGET_HOST=api.openai.com

# Gap 4: latency measurement target.
NEXUS_GAP4_TARGET_HOST=api.openai.com
# Optional: p95 overhead from a prior NE-path measurement (milliseconds).
# Unset = no baseline comparison.
# NEXUS_GAP4_NE_BASELINE_P95_MS=12

# Gap 5: path to Chrome.app for helper-process attribution test.
# Leave unset to skip Gap 5.
# NEXUS_GAP5_CHROME_PATH=/Applications/Google Chrome.app

# Cross-service consistency arm: comma-separated domains to test.
# Defaults to a built-in set of 5 well-known AI provider hosts.
# NEXUS_CONSISTENCY_TEST_DOMAINS=api.openai.com,api.anthropic.com

# Compliance Proxy address for the cross-service consistency arm.
NEXUS_CP_PROXY_ADDR=localhost:3128

# Opt-in gate: set to true to run pf gap-closure tests in run-all.sh.
NEXUS_RUN_MACOS_PF_TESTS=false

# Virtual key for agent-originated test requests (falls back to NEXUS_TEST_VK).
# NEXUS_AGENT_TEST_VK=nvk_REPLACE_ME
