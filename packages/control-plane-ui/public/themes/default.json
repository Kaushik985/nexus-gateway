    "logoTagline": "/brand/prime-console/logo-tagline.svg",
    "favicon": "/brand/prime-console/logo-mark.svg"
  },

  "typography": {
    "fontSans": "'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
    "fontDisplay": "'Inter', ui-sans-serif, system-ui, sans-serif",
    "fontMono": "'JetBrains Mono', 'SF Mono', ui-monospace, monospace"
  },

  "layer1": {
