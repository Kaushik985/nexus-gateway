# tests/.env.prod.example — prod-target test/skill env contract.
#
# Copy to tests/.env.prod (gitignored) and verify values match the
# production deployment. Loaded when NEXUS_TEST_TARGET=prod.
#
# SAFETY: many test scripts mutate state. The prod target is intentionally
# fail-closed across the harness — only scenarios/skills explicitly tagged
# read-only-on-prod may run with target=prod, and the loader requires
# NEXUS_TEST_TARGET=prod explicitly set in the environment (no implicit
# default) to acknowledge the prod target.

# --- Service endpoints ----------------------------------------------------
NEXUS_HUB_URL=https://hub.your-domain.example
NEXUS_CP_URL=https://cp.your-domain.example
NEXUS_AI_GW_URL=https://api.your-domain.example
NEXUS_PROXY_URL=https://compliance.your-domain.example:3128
NEXUS_UI_URL=https://cp.your-domain.example

# --- Postgres (via ssh + psql on the EC2 host) ----------------------------
# When NEXUS_SSH_HOST is set the harness routes psql through ssh; when
# empty it tries docker exec (which fails on prod, correctly).
NEXUS_SSH_HOST=ec2-user@your-prod-host.example
NEXUS_SSH_PGUSER=nexus
NEXUS_SSH_PGPASSWORD=REPLACE_WITH_PROD_PG_PASSWORD
NEXUS_SSH_PGDB=nexus_gateway

# --- Admin login (real OAuth + PKCE flow against prod CP) -----------------
NEXUS_ADMIN_EMAIL=admin@nexus.ai
NEXUS_ADMIN_PASSWORD=REPLACE_WITH_PROD_ADMIN_PASSWORD
NEXUS_OAUTH_CLIENT_ID=cp-ui
NEXUS_OAUTH_REDIRECT_URI=https://cp.your-domain.example/auth/callback
NEXUS_TOKEN_CACHE=/tmp/nexus_test_token_prod

# --- Misc ----------------------------------------------------------------
NEXUS_TEST_VERBOSE=0
NEXUS_TEST_LOG_DIR=/tmp/nexus-test-prod
