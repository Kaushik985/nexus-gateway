{
  "_comment": "One run that stresses TWO ingress protocols of the same gateway at once — OpenAI chat-completions and Anthropic messages. Each scenario overrides protocol+target; the engine, sink, and report are protocol-agnostic.",
  "defaults": {
    "headers": { "Authorization": "Bearer REPLACE_WITH_VK" },
    "model": "claude-haiku-4-5",
    "max_tokens": 64
  },
  "stages": [
    { "concurrency": 20,  "duration": "30s" },
    { "concurrency": 100, "duration": "60s" }
  ],
  "warmup": "5s",
  "cache_mode": "bust",
  "correlation": { "uuid_in_prompt": true, "header": "x-request-id" },
  "scenarios": [
    {
      "name": "openai-ingress", "weight": 50,
      "protocol": "openai-chat", "target": "http://localhost:3050/v1/chat/completions",
      "turns": 1, "stream": false,
      "content": { "mode": "pool", "prompts": ["Explain X in one sentence."] }
    },
    {
      "name": "anthropic-ingress", "weight": 50,
      "protocol": "anthropic", "target": "http://localhost:3050/v1/messages",
      "headers": { "anthropic-version": "2023-06-01" },
      "turns": 1, "stream": true,
      "content": { "mode": "pool", "prompts": ["Explain Y in one sentence."] }
    }
  ]
}
