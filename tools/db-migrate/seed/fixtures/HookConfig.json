    "stage": "request",
    "category": "compliance",
    "endpoint": null,
    "script": null,
    "config": {
      "onMatch": {
        "storageAction": "redact",
        "inflightAction": "block-hard"
      },
      "patternDefinitions": [
        {
          "id": "email",
          "flags": "g",
          "regex": "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}\\b"
        },
        {
          "id": "credit_card",
          "flags": "g",
          "regex": "\\b(?:\\d{4}[-\\s]?){3}\\d{4}\\b"
        },
        {
          "id": "ssn",
          "flags": "g",
          "regex": "\\b\\d{3}[-\\s]?\\d{2}[-\\s]?\\d{4}\\b"
        },
        {
          "id": "phone",
          "flags": "g",
          "regex": "\\b(?:\\+?1[-.\\s]?)?(?:\\(?\\d{3}\\)?[-.\\s]?)?\\d{3}[-.\\s]?\\d{4}\\b"
        }
      ]
    },
