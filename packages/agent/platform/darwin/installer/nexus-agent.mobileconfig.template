<?xml version="1.0" encoding="UTF-8"?>
<!--
  MDM configuration profile for the Nexus Agent.
  Pre-approves, with no end-user prompts, all three approvals the agent needs on
  a managed Mac deployed through Jamf, Mosyle, Kandji, Intune, or another MDM:
    - the System / Network Extension (com.apple.system-extension-policy),
    - the content-filter capability (com.apple.webcontent-filter),
    - the SMAppService boot daemon + login item (com.apple.servicemanagement).
  With this profile installed, SMAppService.daemon/.mainApp register() lands
  directly in .enabled, so the menu app never shows the "finish setup" row.

  Note on NON-REMOVABILITY: this profile sets PayloadRemovalDisallowed so the
  PROFILE cannot be removed by the user. Making the APP itself non-removable is
  a separate MDM managed-app attribute (Jamf/Intune "prevent removal" on the
  app deployment), not a config-profile payload — see the operator runbook.

  USAGE:
    1. Replace {{TEAM_ID}} with your Apple Developer Team ID (10 characters).
    2. Replace {{ORGANIZATION}} with your organization name.
    3. Replace {{PROFILE_UUID}} with a fresh UUID (uuidgen).
    4. Upload the resulting .mobileconfig to your MDM and assign to managed Macs.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>PayloadContent</key>
    <array>
        <!-- System Extension policy: pre-approve com.nexus-gateway.agent for the configured Team. -->
        <dict>
            <key>PayloadType</key>
            <string>com.apple.system-extension-policy</string>
            <key>PayloadIdentifier</key>
            <string>com.nexus-gateway.agent.systemextension-policy</string>
            <key>PayloadUUID</key>
            <string>{{PROFILE_UUID}}</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>PayloadDisplayName</key>
            <string>Nexus Agent System Extension</string>
            <key>PayloadDescription</key>
            <string>Allows the Nexus Agent network extension to load without user prompts.</string>
            <key>AllowUserOverrides</key>
            <false/>
            <key>AllowedSystemExtensions</key>
            <dict>
                <key>{{TEAM_ID}}</key>
                <array>
                    <string>com.nexus-gateway.agent</string>
                </array>
            </dict>
            <key>AllowedSystemExtensionTypes</key>
            <dict>
                <key>{{TEAM_ID}}</key>
                <array>
                    <string>NetworkExtension</string>
                </array>
            </dict>
        </dict>

        <!-- Content Filter capability: required for the transparent proxy provider. -->
        <dict>
            <key>PayloadType</key>
            <string>com.apple.webcontent-filter</string>
            <key>PayloadIdentifier</key>
            <string>com.nexus-gateway.agent.contentfilter</string>
            <key>PayloadUUID</key>
            <string>{{PROFILE_UUID}}-cf</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>PayloadDisplayName</key>
            <string>Nexus Agent Content Filter</string>
            <key>FilterType</key>
            <string>Plugin</string>
            <key>UserDefinedName</key>
            <string>Nexus Agent</string>
            <key>PluginBundleID</key>
            <string>com.nexus-gateway.agent</string>
            <key>FilterSockets</key>
            <true/>
            <key>FilterPackets</key>
            <false/>
        </dict>

        <!-- Service Management: pre-approve the SMAppService boot daemon and the
             menu-bar login item, both registered by the com.nexus-gateway.agent
             app. Without this the user must approve them once in System Settings
             → General → Login Items & Extensions; with it, register() lands in
             .enabled silently on a managed device. -->
        <dict>
            <key>PayloadType</key>
            <string>com.apple.servicemanagement</string>
            <key>PayloadIdentifier</key>
            <string>com.nexus-gateway.agent.servicemanagement</string>
            <key>PayloadUUID</key>
            <string>{{PROFILE_UUID}}-sm</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>PayloadDisplayName</key>
            <string>Nexus Agent Background Services</string>
            <key>PayloadDescription</key>
            <string>Pre-approves the Nexus Agent daemon and login item so they run without user consent.</string>
            <key>Rules</key>
            <array>
                <dict>
                    <key>RuleType</key>
                    <string>BundleIdentifier</string>
                    <key>RuleValue</key>
                    <string>com.nexus-gateway.agent</string>
                </dict>
            </array>
        </dict>
    </array>
    <key>PayloadDisplayName</key>
    <string>Nexus Agent Configuration</string>
    <key>PayloadIdentifier</key>
    <string>com.nexus-gateway.agent.configuration</string>
    <key>PayloadOrganization</key>
    <string>{{ORGANIZATION}}</string>
    <key>PayloadRemovalDisallowed</key>
    <true/>
    <key>PayloadType</key>
    <string>Configuration</string>
    <key>PayloadUUID</key>
    <string>{{PROFILE_UUID}}-root</string>
    <key>PayloadVersion</key>
    <integer>1</integer>
    <key>PayloadDescription</key>
    <string>Configures the Nexus Agent network extension and content filter on managed devices.</string>
</dict>
</plist>
