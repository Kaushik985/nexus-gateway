# benchmark/v2/.env.local — local dev environment for the benchmark runner.
#
# This file is gitignored (see repo-root .gitignore: benchmark/v2/.env.local).
# It is auto-loaded by engine/models.py via python-dotenv with override=False,
# so already-exported shell vars always win.
#
# HOW TO FILL THIS IN
# -------------------
# NEXUS_API_KEY    — create a Virtual Key via the Nexus Control Plane UI
#                    (Gateway -> Virtual Keys -> New Key) or via the admin API:
#                      curl -s -X POST http://localhost:3001/api/admin/virtual-keys \
#                        -H "Authorization: Bearer <your-nxk-admin-key>" \
#                        -H "Content-Type: application/json" \
#                        -d '{"name":"benchmark-dev","type":"application"}'
#                    The response body includes the plaintext key (nvk_...).
#
# NEXUS_ADMIN_API_KEY — an AdminApiKey with virtual-key create permission.
#                    After `npx prisma db seed`, the seed inserts a
#                    "local-dev-super-admin" key with prefix nxk_01234567,
#                    but only its HASH is stored. You must create a fresh key
#                    via the CP UI (Settings -> API Keys -> Generate) or run:
#                      cp_login && cp_curl POST /api/user/api-keys \
#                        '{"name":"benchmark-admin","scopes":["admin:virtual-key.*"]}'
#                    That returns the plaintext nxk_... key once.
#
# LITELLM_API_KEY  — set to the LiteLLM master key configured in your local
#                    LiteLLM instance. If you started LiteLLM with
#                    LITELLM_MASTER_KEY=sk-local-dev, use that value here.
#                    Any non-empty string works when LiteLLM runs without auth.
#
# BIFROST_API_KEY  — the static API key Bifrost is configured to accept.
#                    Bifrost reads this from its own config/env at startup.
#                    For local dev with default Bifrost config, any non-empty
#                    string (e.g. "local-dev") is accepted when auth is disabled.
#
# BLOCKER: NEXUS_API_KEY and NEXUS_ADMIN_API_KEY cannot be derived from the
# seed alone — the seed stores only hashed values. These must be obtained via
# the CP UI or admin API after the Nexus stack is running locally.

# ── Nexus AI Gateway ────────────────────────────────────────────────────────
# Base URL: default port is 3050, matching docker-compose.yml comment and
# AI_GATEWAY_PORT in .env.example.
NEXUS_BASE_URL=http://localhost:3050

# Virtual Key for benchmark traffic (nvk_... prefix).
# BLOCKER: obtain from CP UI or admin API — see instructions above.
NEXUS_API_KEY=nvk_...REPLACE_WITH_ACTIVE_VK_FROM_GATEWAY_DB...

# Admin URL: Control Plane runs on 3001.
NEXUS_ADMIN_URL=http://localhost:3001

# Admin API key for config_validator (nxk_... prefix).
# BLOCKER: generate via CP UI (Settings -> API Keys) after local stack is up.
NEXUS_ADMIN_API_KEY=nxk_...REPLACE_WITH_ADMIN_API_KEY...

# ── Nexus admin OAuth (required by scripts/hooks_toggle.sh) ──────────────────
# hooks_toggle.sh drives the CP OAuth+PKCE login to enable/disable compliance
# hooks for the hooks A/B run. These three are REQUIRED for that script.
NEXUS_ADMIN_EMAIL=admin@nexus.ai
NEXUS_ADMIN_PASSWORD=REPLACE_WITH_ADMIN_PASSWORD
# Must match a redirect URI registered for the cp-ui OAuth client. On AWS use
# the instance's scheme/host, e.g. https://<nexus-ip>/auth/callback
NEXUS_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
# CP base URL that hooks_toggle.sh + admin calls hit. Default localhost:3001.
#  AWS GOTCHA: the CP is fronted by nginx on :443 (https://<nexus-ip>), NOT
#  reachable on :3001 from outside the box. If the benchmark runner is a SEPARATE
#  instance from Nexus, set this (and NEXUS_ADMIN_URL above) to the nginx HTTPS
#  URL, e.g. NEXUS_CP_URL=https://<REDACTED-IP> . Port 3001 is internal only.
#  (verify=False in the harness handles the self-signed cert.)
NEXUS_CP_URL=http://localhost:3001
NEXUS_OAUTH_CLIENT_ID=cp-ui
# Optional: pin the AI-gateway node id to skip auto-discovery in hooks_toggle.sh.
# Format: gw-ip-<private-ip-with-dashes>.ec2.internal-3050
# Get it from: GET /api/admin/nodes once the stack is up.
# NEXUS_GW_NODE_ID=
# Optional: override the openai-prod credential id for circuit-reset
# (default is the local-seed id; differs on AWS).
# NEXUS_OPENAI_CREDENTIAL_ID=

# ── LiteLLM ─────────────────────────────────────────────────────────────────
# Default port from LiteLLM docs / community convention.
LITELLM_BASE_URL=http://localhost:4000

# LiteLLM master key or any key accepted by your local instance.
# If you started LiteLLM with --master_key sk-local-dev, put that value here.
# For no-auth mode, any non-empty string works.
LITELLM_API_KEY=sk-local-dev

# ── Bifrost ──────────────────────────────────────────────────────────────────
# Default Bifrost listen port (see Bifrost docs / their docker-compose examples).
BIFROST_BASE_URL=http://localhost:8080

# Bifrost API key. When Bifrost auth is disabled this value is still sent in
# the Authorization header but not validated — any non-empty string is fine.
BIFROST_API_KEY=local-dev

# OPEN AI API KEY
OPENAI_API_KEY=sk-...REPLACE_WITH_FUNDED_KEY...
