enum AlertSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum AlertState {
  FIRING
  ACKNOWLEDGED
  RESOLVED
}

model AlertRule {
  id              String        @id // e.g. "quota.threshold"
  displayName     String
  sourceType      String // quota | proxy | thing | provider | auth | system
  defaultSeverity AlertSeverity
  requiresAck     Boolean       @default(false)
  enabled         Boolean       @default(true)
  params          Json
  paramsSchema    Json
  cooldownSec     Int           @default(300)
  /// E52-S12 optional per-group filter. When non-NULL the rule only
  /// fires for events whose target (device) is a member of this
  /// DeviceGroup. NULL = fleet-wide (today's behaviour).
  group_id_filter String?       @map("group_id_filter")
  groupFilter     DeviceGroup?  @relation("AlertRuleGroupFilter", fields: [group_id_filter], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime      @updatedAt @db.Timestamptz(3)

  alerts Alert[]

  @@index([sourceType, enabled])
  @@index([group_id_filter], map: "alert_rule_group_filter_idx")
}

model Alert {
  id             String        @id @default(uuid())
  ruleId         String
  rule           AlertRule     @relation(fields: [ruleId], references: [id])
  sourceType     String
  targetKey      String
  targetLabel    String
  severity       AlertSeverity
  state          AlertState    @default(FIRING)
  message        String
  details        Json
  firedAt        DateTime      @db.Timestamptz(3)
  lastSeenAt     DateTime      @db.Timestamptz(3)
  duplicateCount Int           @default(1)
  acknowledgedBy String?
  acknowledgedAt DateTime?     @db.Timestamptz(3)
  resolvedAt     DateTime?     @db.Timestamptz(3)
  resolvedBy     String?
  resolvedReason String?

  dispatches AlertDispatch[]

  @@index([state, sourceType, firedAt])
  @@index([ruleId, targetKey, state])
  @@index([firedAt])
}

model AlertChannel {
  id          String   @id @default(uuid())
  name        String
  type        String // webhook | slack | email | pagerduty
  enabled     Boolean  @default(true)
  severities  String[]
  sourceTypes String[]
  config      Json
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)
}

model AlertDispatch {
  id          String   @id @default(uuid())
  alertId     String
  alert       Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  channelId   String
  channelName String
  success     Boolean
  statusCode  Int?
  errorMsg    String?
  attemptedAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([alertId])
  @@index([attemptedAt])
}

/// 5-minute rollup bucket for pre-aggregated metrics.
model MetricRollup5m {
  id           String   @id @default(uuid())
  bucketStart  DateTime @db.Timestamptz(3)
  metricName   String
  dimensionKey String   @default("")
  subDimension String   @default("")
  value        Decimal  @default(0) @db.Decimal(24, 6)
  metadata     Json?
  updatedAt    DateTime @default(now()) @db.Timestamptz(3)

  @@unique([bucketStart, metricName, dimensionKey, subDimension])
  @@index([metricName, bucketStart])
  @@index([dimensionKey, bucketStart])
  @@map("metric_rollup_5m")
}

