<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- No sandbox: LaunchDaemon runs as root, sandbox is inapplicable. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- Outbound network access for Hub connection and audit upload. -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Inbound socket for the platform bridge (127.0.0.1:19080). -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- Hardened Runtime: allow dynamic code (Go runtime requires this). -->
    <key>com.apple.security.cs.allow-jit</key>
    <false/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <false/>
</dict>
</plist>
