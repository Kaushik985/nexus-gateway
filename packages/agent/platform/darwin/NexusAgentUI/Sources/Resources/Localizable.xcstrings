    "quit.fallbackWarning" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "This will stop the Nexus Agent daemon entirely. Your device will no longer be protected by company policies until you re-launch the app. To switch accounts, use Sign Out instead." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "这会完全停止 Nexus Agent 守护进程。在你重新打开 App 之前，本设备不再受公司策略保护。如果只是想换账号，请改用「退出登录」。" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Esto detendrá por completo el daemon de Nexus Agent. Hasta que vuelva a abrir la app, este dispositivo dejará de estar protegido por las políticas de la empresa. Para cambiar de cuenta, use Cerrar sesión." } }
      }
