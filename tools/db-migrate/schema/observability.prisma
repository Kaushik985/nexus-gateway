/// 5-minute rollup bucket for per-Thing traffic metrics.
///
/// Sibling of MetricRollup5m, kept in a dedicated table so per-Thing access
/// patterns (one Thing's dashboard) don't share row counts or indexes with
/// fleet-wide queries. Populated only when the source traffic_event row has a
/// non-null thing_id — i.e. data plane services (agent / compliance-proxy /
/// ai-gateway). Fleet readers continue to use MetricRollup5m unchanged.
model ThingMetricRollup5m {
  id           String   @id @default(uuid())
  bucketStart  DateTime @db.Timestamptz(3)
  thingId      String   @map("thing_id")
  metricName   String
  dimensionKey String   @default("")
  subDimension String   @default("")
  value        Decimal  @default(0) @db.Decimal(24, 6)
  metadata     Json?
  updatedAt    DateTime @default(now()) @db.Timestamptz(3)

  @@unique([bucketStart, thingId, metricName, dimensionKey, subDimension])
  @@index([thingId, metricName, bucketStart])
  @@index([thingId, bucketStart])
  @@map("thing_metric_rollup_5m")
}

