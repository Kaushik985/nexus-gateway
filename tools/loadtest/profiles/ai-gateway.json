{
  "defaults": {
    "protocol": "openai-chat",
    "target": "http://localhost:3050/v1/chat/completions",
    "headers": { "Authorization": "Bearer REPLACE_WITH_VK" },
    "model": "claude-haiku-4-5",
    "max_tokens": 64
  },
  "stages": [
    { "concurrency": 1,    "duration": "15s" },
    { "concurrency": 50,   "duration": "60s" },
    { "concurrency": 200,  "duration": "60s" },
    { "concurrency": 500,  "duration": "60s" },
    { "concurrency": 1000, "duration": "120s" }
  ],
  "warmup": "10s",
  "cache_mode": "bust",
  "correlation": { "uuid_in_prompt": true, "header": "x-request-id" },
  "thresholds": { "ttft_p95_ms": 0, "p95_ms": 0, "error_rate": 0.01 },
  "scenarios": [
    {
      "name": "quick-qa", "weight": 70, "turns": 1, "stream": false, "max_tokens": 64,
      "content": { "mode": "pool", "prompts": [
        "Explain database connection pooling in one sentence.",
        "Define p99 latency briefly.",
        "What is time-to-first-token?"
      ] }
    },
    {
      "name": "chat", "weight": 20, "turns": { "min": 3, "max": 6 }, "stream": true, "max_tokens": 128,
      "content": { "mode": "scripted", "script": [
        "Hi, I have a question about gateway latency.",
        "Can you elaborate on what dominates it?",
        "And how does concurrency change that?",
        "Summarize what we discussed in two lines."
      ] }
    },
    {
      "name": "long-ctx", "weight": 10, "turns": 2, "stream": true, "max_tokens": 256,
      "content": { "mode": "sized", "approx_input_tokens": 2000 }
    }
  ]
}
