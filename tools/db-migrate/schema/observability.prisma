/// Tracks high-water mark for each rollup job to ensure exactly-once computation.
model RollupWatermark {
  jobName   String   @id
  watermark DateTime @db.Timestamptz(3)
  updatedAt DateTime @default(now()) @db.Timestamptz(3)

  @@map("rollup_watermark")
}

/// Real-time ops metric samples reported by every Thing (services + agents).
/// `value` is nullable because histograms put their data in `metadata.buckets`.
model MetricOpsRaw {
  id           String   @default(uuid()) @db.Uuid
  sampledAt    DateTime @map("sampled_at") @db.Timestamptz(6)
  thingId      String   @map("thing_id")
  thingType    String   @map("thing_type")
  metricName   String   @map("metric_name")
  metricKind   String   @map("metric_kind")
  dimensionKey String   @default("") @map("dimension_key")
  value        Float?   @db.DoublePrecision
  metadata     Json?

  thing Thing @relation(fields: [thingId], references: [id], onDelete: Cascade)

  // metric_ops_raw is RANGE-partitioned by sampled_at at the DB level (see
  // migration 20260613000002_partition_metric_ops_raw). A partitioned table's
  // primary key must include the partition key, so id is paired with sampledAt.
  @@id([sampledAt, id])
  @@unique([sampledAt, thingId, metricName, dimensionKey])
  @@index([thingId, sampledAt(sort: Desc)])
  @@index([metricName, sampledAt(sort: Desc)])
  @@index([thingType, sampledAt(sort: Desc)])
  @@map("metric_ops_raw")
}

/// 5-minute rollup — the smallest persisted aggregation tier. metric_ops_raw is
/// aggregated into this table by the ops-rollup-5m job; the 1h/1d/1mo tiers
/// cascade from here. Same shape as MetricOpsRollup1h; real uniqueness via the
/// `uq_ops_rollup_5m` partial-COALESCE UNIQUE INDEX added in raw SQL.
model MetricOpsRollup5m {
  id           String   @id @default(uuid()) @db.Uuid
  bucketStart  DateTime @map("bucket_start") @db.Timestamptz(6)
  thingId      String?  @map("thing_id")
  thingType    String   @map("thing_type")
  metricName   String   @map("metric_name")
  metricKind   String   @map("metric_kind")
  dimensionKey String   @default("") @map("dimension_key")
  valueAvg     Float?   @map("value_avg") @db.DoublePrecision
  valueSum     Float?   @map("value_sum") @db.DoublePrecision
  valueMin     Float?   @map("value_min") @db.DoublePrecision
  valueMax     Float?   @map("value_max") @db.DoublePrecision
  sampleCount  Int      @map("sample_count")
  metadata     Json?

  @@index([metricName, bucketStart(sort: Desc)])
  @@map("metric_ops_rollup_5m")
}

/// 1-hour rollup. `thingId` is nullable: NULL means the row is a fleet aggregate.
/// `id` is a synthetic primary key required only because Prisma cannot express
/// the natural composite key (COALESCE(thing_id, sentinel) with NOT NULL
/// semantics). The real uniqueness constraint is enforced by the
/// `uq_ops_rollup_1h` partial-COALESCE UNIQUE INDEX added in raw SQL.
model MetricOpsRollup1h {
  id           String   @id @default(uuid()) @db.Uuid
  bucketStart  DateTime @map("bucket_start") @db.Timestamptz(6)
  thingId      String?  @map("thing_id")
  thingType    String   @map("thing_type")
  metricName   String   @map("metric_name")
  metricKind   String   @map("metric_kind")
  dimensionKey String   @default("") @map("dimension_key")
  valueAvg     Float?   @map("value_avg") @db.DoublePrecision
  valueSum     Float?   @map("value_sum") @db.DoublePrecision
  valueMin     Float?   @map("value_min") @db.DoublePrecision
  valueMax     Float?   @map("value_max") @db.DoublePrecision
  sampleCount  Int      @map("sample_count")
  metadata     Json?

  @@index([metricName, bucketStart(sort: Desc)])
  @@map("metric_ops_rollup_1h")
}

