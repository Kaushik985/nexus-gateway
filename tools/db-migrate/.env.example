# Local dev template for tools/db-migrate.
#
# Bootstrap: `scripts/dev-start.sh` copies this file to `.env` on first run.
# Manual:    `cp .env.example .env` from this directory.
#
# `.env` is gitignored so each developer can override locally.

# ─── Database ───────────────────────────────────────────────────────────────
# Default points at the postgres container started by `docker-compose.yml`
# at the repo root (port 55532 -> container 5432).
DATABASE_URL="postgresql://postgres:postgres@localhost:55532/nexus_gateway"

# ─── Optional: seed-time secrets ────────────────────────────────────────────
# Used by tools/db-migrate/seed/. Both have safe dev fallbacks; set them
# explicitly only if you need stable values across re-seeds or want to
# match what a Go service is configured with.
#
# 32-byte hex key for credential AES encryption. Leave unset in dev to use
# the seed's built-in dev key.
# CREDENTIAL_ENCRYPTION_KEY=
#
# HMAC secret for hashing admin API keys (nxk_*). Leave unset to use the
# dev fallback in seed/lib.ts; must match the value the control-plane
# verifies with at runtime.
# ADMIN_KEY_HMAC_SECRET=
