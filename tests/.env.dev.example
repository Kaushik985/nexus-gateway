# tests/.env.dev.example — dev-target test/skill env contract.
#
# Copy to tests/.env.dev (gitignored) and fill in real values for a shared
# dev/staging cluster. Loaded when NEXUS_TEST_TARGET=dev.
#
# Placeholders below assume a `dev.nexus.internal` deployment. Replace with
# your actual dev hostname before running anything that mutates state.

NEXUS_HUB_URL=https://dev.nexus.internal
NEXUS_CP_URL=https://dev.nexus.internal
NEXUS_AI_GW_URL=https://dev-api.nexus.internal
NEXUS_PROXY_URL=https://dev-cp.nexus.internal:3128
NEXUS_UI_URL=https://dev.nexus.internal

NEXUS_SSH_HOST=ec2-user@dev.nexus.internal
NEXUS_SSH_PGUSER=nexus
NEXUS_SSH_PGPASSWORD=REPLACE_WITH_DEV_PG_PASSWORD
NEXUS_SSH_PGDB=nexus_gateway

NEXUS_ADMIN_EMAIL=admin@nexus.ai
NEXUS_ADMIN_PASSWORD=REPLACE_WITH_DEV_ADMIN_PASSWORD
NEXUS_OAUTH_CLIENT_ID=cp-ui
NEXUS_OAUTH_REDIRECT_URI=https://dev.nexus.internal/auth/callback
NEXUS_TOKEN_CACHE=/tmp/nexus_test_token_dev

NEXUS_TEST_VERBOSE=0
NEXUS_TEST_LOG_DIR=/tmp/nexus-test-dev
