/// Per-layer retention policy for ops metrics + diag events. Updated via the
/// admin Control Plane API; consumed by the ops-retention scheduled job.
model MetricOpsRetentionConfig {
  layer         String   @id
  retentionDays Int      @map("retention_days")
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy     String?  @map("updated_by")

  updatedByUser NexusUser? @relation("MetricOpsRetentionConfigUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@map("metric_ops_retention_config")
}
